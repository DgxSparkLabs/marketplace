{
  "markdown": {
    "command": "uv",
    "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/example_lsp.py", "--lang", "markdown", "--always-error"],
    "extensionToLanguage": {
      ".md": "markdown",
      ".markdown": "markdown"
    }
  },
  "python": {
    "command": "uv",
    "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/example_lsp.py", "--lang", "python", "--always-error"],
    "extensionToLanguage": {
      ".py": "python",
      ".pyi": "python"
    }
  }
}
