{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "./scripts/pre-commit.sh",
        "matcher": "^git commit"
      }
    ],
    "afterFileEdit": [
      { "command": "node ./scripts/format-schema.js" },
      { "command": "node ./scripts/generate-types.js" }
    ]
  }
}
